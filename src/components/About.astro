---
import { getEntry, render } from "astro:content";

const about = await getEntry("about", "about");

if (!about) {
	throw new Error("About content not found");
}

const { Content } = await render(about);
---

<section
	id="about"
	class="h-screen w-full flex items-center justify-center px-6 md:px-12 snap-start bg-[#F8F6E1] text-[#355C35]"
>
	<div class="max-w-4xl w-full">
		<div class="mb-6">
			<h2 class="text-3xl md:text-5xl font-bold">{about.data.texto1}</h2>
			<h2 class="text-3xl md:text-5xl font-medium">
				{about.data.texto2}
			</h2>
		</div>
		<Content class="text-base md:text-lg leading-relaxed max-w-2xl" />
	</div>
</section>
