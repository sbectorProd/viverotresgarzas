---
import Section from "@/components/ui/Section.astro";
import Container from "@/components/ui/Container.astro";
import Logo from "@/components/ui/svg/Logo.astro";

import { getEntry, render } from "astro:content";

const about = await getEntry("about", "about");

if (!about) {
	throw new Error("About content not found");
}

const bullets = about.data.bullets ?? [];
const [bullet1, bullet2, bullet3, bullet4] = bullets;
const { Content } = await render(about);
---

<!-- 🔹 SECCIÓN 1: DIAGRAMA -->
<Section id="nosotros" align="end" justify="center">
	<Container
		className="relative flex flex-col items-center justify-center gap-10 md:min-w-7/8 md:gap-0 min-h-[80dvh]"
	>
		<!-- 🟢 MOBILE (stack) -->
		<div
			class="flex flex-col items-center text-center gap-6 md:hidden text-base"
		>
			{bullets.map((item) => (
				<p>{item}</p>
			))}

			<Logo class="w-20 text-current" />
		</div>

		<!-- 🟢 DESKTOP (diagrama) -->
		<div class="hidden md:block w-full h-full relative">
			<div class="absolute inset-0 pointer-events-none">
				<svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
					<g stroke="#355C35" stroke-width="2" stroke-linecap="round" fill="none">
						<line x1="24" y1="20" x2="50" y2="50" />
						<line x1="24" y1="80" x2="50" y2="50" />
						<line x1="76" y1="20" x2="50" y2="50" />
						<line x1="76" y1="80" x2="50" y2="50" />
						<circle cx="24" cy="20" r="2.5" fill="#355C35" />
						<circle cx="24" cy="80" r="2.5" fill="#355C35" />
						<circle cx="76" cy="20" r="2.5" fill="#355C35" />
						<circle cx="76" cy="80" r="2.5" fill="#355C35" />
					</g>
				</svg>
			</div>

			{bullet1 && (
				<div class="absolute left-8 top-16 w-60 text-base lg:text-2xl">
					{bullet1}
				</div>
			)}

			{bullet3 && (
				<div class="absolute left-8 bottom-16 w-60 text-base lg:text-2xl">
					{bullet3}
				</div>
			)}

			{bullet2 && (
				<div class="absolute right-8 top-16 w-60 text-base lg:text-2xl text-right">
					{bullet2}
				</div>
			)}

			{bullet4 && (
				<div class="absolute right-8 bottom-16 w-60 text-base lg:text-2xl text-right">
					{bullet4}
				</div>
			)}

			<!-- CENTRO -->
			<div class="absolute inset-0 flex items-center justify-center">
				<Logo class="w-28 lg:w-40 text-current" />
			</div>
		</div>
	</Container>
</Section>

<!-- 🔹 SECCIÓN 2: TEXTO -->
<Section align="center" justify="center">
	<Container
		className="flex flex-col items-center text-center gap-6 max-w-3xl"
	>
		<p class="text-base lg:text-2xl tracking-wide">
			{about.data.texto1}
		</p>

		<img src="/arbol.png" alt="Árbol" class="w-16 md:w-38 py-6" />

		<div class="text-base lg:text-2xl tracking-wide">
			{about.data.texto2}
		</div>
	</Container>
</Section>
