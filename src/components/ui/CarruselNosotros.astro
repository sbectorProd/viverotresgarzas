---
const { items = [] } = Astro.props;
const slides = Array.isArray(items) ? items : [];
const defaultImages = [
    "/EMIF9474.webp",
    "/EMIF9470.webp",
    "/EMIF9424.webp",
    "/EMIF9474.webp",
];
---

<div class="relative w-full h-dvh">
    <div
        id="carousel-track"
        class="overflow-x-auto snap-x snap-mandatory scroll-smooth hide-scrollbar flex h-full"
        tabindex="0"
        aria-label="Carrusel de slides"
    >
        <div class="flex h-full">
            {
                slides.map((slide, index) => {
                    const item =
                        typeof slide === "string" ? { text: slide } : slide;
                    const title = item.title;
                    const text = item.text ?? item.title ?? "";
                    const image =
                        item.image ??
                        defaultImages[index % defaultImages.length];

                    return (
                        <article
                            id={`slide-${index}`}
                            class="relative snap-center shrink-0 w-dvw h-full"
                            data-slide-idx={index}
                        >
                            <div class="absolute top-0 right-0 w-full lg:w-1/2 h-full overflow-hidden">
                                <img
                                    src={image}
                                    alt={title ?? text.substring(0, 50)}
                                    class="h-full w-full object-cover"
                                />
                            </div>
                            <div class="relative z-10 flex flex-col justify-end h-full w-full lg:w-1/2 px-8 pb-16 lg:px-16 lg:pb-20 text-primario">
                                <div class="bg-fondo/80 backdrop-blur-sm rounded-xl px-5 py-4 lg:bg-transparent lg:backdrop-blur-none lg:p-0">
                                    {title && (
                                        <h3 class="mb-3 lg:mb-6 type-h2 text-primario">
                                            {title}
                                        </h3>
                                    )}
                                    <p class="max-w-md type-body text-primario/80">
                                        {text}
                                    </p>
                                </div>
                            </div>
                        </article>
                    );
                })
            }
        </div>
    </div>

    <div id="carousel-dots" class="absolute bottom-6 left-8 lg:left-16 z-20 flex gap-3">
        {
            slides.map((slide, index) => (
                <button
                    type="button"
                    class="inline-flex h-3 w-3 rounded-full border transition-all duration-300 bg-transparent border-fondo md:border-primario/50 md:bg-transparent"
                    aria-label={`Ir al slide ${index + 1}`}
                    data-dot-idx={index}
                />
            ))
        }
    </div>

    <style>
        .hide-scrollbar::-webkit-scrollbar {
            display: none;
        }
        .hide-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
        .dot-active {
            background-color: var(--color-fondo, #fff);
            border-color: var(--color-fondo, #fff);
        }
        @media (min-width: 768px) {
            .dot-active {
                background-color: var(--color-primario, #1a202c);
                border-color: var(--color-primario, #1a202c);
            }
        }
    </style>

    <script type="module">
        const track = document.getElementById('carousel-track');
        const slides = Array.from(track.querySelectorAll('[data-slide-idx]'));
        const dots = Array.from(document.querySelectorAll('[data-dot-idx]'));
        let activeIdx = 0;

        function setActiveDot(idx) {
            dots.forEach((dot, i) => {
                dot.classList.toggle('dot-active', i === idx);
            });
        }

        function scrollToSlide(idx, smooth = true) {
            const slide = slides[idx];
            if (!slide) return;
            slide.scrollIntoView({ behavior: smooth ? 'smooth' : 'auto', inline: 'center', block: 'nearest' });
            activeIdx = idx;
            setActiveDot(idx);
        }

        function getMostVisibleSlideIdx() {
            let maxVisible = 0, maxIdx = 0;
            slides.forEach((slide, idx) => {
                const rect = slide.getBoundingClientRect();
                const visible = Math.max(0, Math.min(rect.right, window.innerWidth) - Math.max(rect.left, 0));
                if (visible > maxVisible) {
                    maxVisible = visible;
                    maxIdx = idx;
                }
            });
            return maxIdx;
        }

        function syncActiveDotWithScroll() {
            const idx = getMostVisibleSlideIdx();
            if (idx !== activeIdx) {
                activeIdx = idx;
                setActiveDot(idx);
            }
        }

        // Dots click
        dots.forEach((dot, idx) => {
            dot.addEventListener('click', () => {
                scrollToSlide(idx);
            });
        });

        // Scroll/Swipe sync
        track.addEventListener('scroll', () => {
            syncActiveDotWithScroll();
        }, { passive: true });

        // Init
        setActiveDot(0);

        // Fallback for browsers without smooth scroll
        if (!('scrollBehavior' in document.documentElement.style)) {
            scrollToSlide = function(idx) {
                const slide = slides[idx];
                if (!slide) return;
                slide.scrollIntoView();
                activeIdx = idx;
                setActiveDot(idx);
            };
        }
    </script>
</div>
