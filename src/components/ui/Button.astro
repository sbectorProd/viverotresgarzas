---
interface Props {
  href?: string;
  variant?: "outline" | "solid" | "inverse";
  className?: string;
}

const {
  href,
  variant = "outline",
  className = "",
} = Astro.props as Props;

const base =
  "inline-flex items-center justify-center rounded-full transition-all duration-300 px-4 py-2 text-sm md:px-5 md:py-2.5 md:text-base lg:px-6 lg:py-2.5 lg:text-xl";

const variants = {
  outline:
    "border border-primario text-primario hover:bg-primario hover:text-fondo",
  solid:
    "bg-primario text-fondo hover:bg-[#2a472a]",
  inverse:
    "border border-fondo text-fondo hover:bg-fondo hover:text-primario",
};
---

{href ? (
  <a href={href} class={`${base} ${variants[variant]} ${className} font-brand`}>
    <slot />
  </a>
) : (
  <button class={`${base} ${variants[variant]} ${className} font-brand`}>
    <slot />
  </button>
)}