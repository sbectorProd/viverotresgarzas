---
import MobileMenu from "@/components/ui/MobileMenu.astro";
import Logo from "@/components/ui/Logo.astro";
---

<header
    id="site-header"
    class="fixed top-0 left-0 w-full z-50 px-6 md:px-12 py-5 md:py-6 flex justify-between items-center"
>
    <!-- LOGO -->
    <div
        class="text-current text-lg md:text-xl lg:text-2xl tracking-wide font-medium"
    >
         <Logo class="w-40 text-current"/>
    </div>

    <!-- DESKTOP NAV -->
    <nav
        class="hidden md:flex gap-8 lg:gap-12 text-sm md:text-base lg:text-lg text-current tracking-wide"
    >
        <a href="#inicio">Inicio</a>
        <a href="#nosotros">Nosotros</a>
        <a href="#catalogo">Catálogo</a>
        <a href="#contacto">Contacto</a>
    </nav>

    <!-- HAMBURGER -->
    <button id="menu-btn" class="md:hidden flex flex-col gap-1.5">
        <span class="w-6 h-0.5 bg-current"></span>
        <span class="w-6 h-0.5 bg-current"></span>
        <span class="w-6 h-0.5 bg-current"></span>
    </button>

    <!-- MENU -->
    <MobileMenu open={false} />
</header>

<script>
    const header = document.getElementById("site-header") as HTMLElement;
    const sections = document.querySelectorAll("section");
    

    const observer = new IntersectionObserver(
        (entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    const id = entry.target.id;

                    if (id === "inicio") {
                        header.classList.add("text-fondo");
                        header.classList.remove("text-primario");
                    } else {
                        header.classList.add("text-primario");
                        header.classList.remove("text-fondo");
                    }
                }
            });
        },
        {
            threshold: 0.6,
        },
    );

    sections.forEach((section) => observer.observe(section));
</script>
