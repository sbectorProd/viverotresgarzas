---
import { menú } from "@/constants.ts";
import MobileMenu from "@/components/ui/MobileMenu.astro";
import LogoHeader from "@/components/ui/svg/LogoHeader.astro";
---

<header
    id="site-header"
    class="fixed top-0 left-0 w-full z-50 px-6 md:px-12 py-5 md:py-8 flex justify-between items-center transition-all duration-300 bg-transparent"
>
    <!-- LOGO -->
    <a href="#inicio">
        <LogoHeader class="w-40 lg:w-80 text-current" />
    </a>

    <!-- DESKTOP NAV -->
    <nav
        class="hidden md:flex gap-8 lg:gap-12 text-sm md:text-base lg:text-2xl text-current tracking-wide"
    >
        {
            menú.map((item) => (
                <a href={item.href} class="hover:opacity-70">
                    {item.name}
                </a>
            ))
        }
    </nav>

    <!-- HAMBURGER -->
    <button id="menu-btn" class="md:hidden flex flex-col gap-1.5">
        <span class="w-6 h-0.5 bg-current"></span>
        <span class="w-6 h-0.5 bg-current"></span>
        <span class="w-6 h-0.5 bg-current"></span>
    </button>

    <!-- MENU -->
    <MobileMenu open={false} />
</header>

<script>
    const header = document.getElementById("site-header") as HTMLElement;
    const sections = document.querySelectorAll("section");
    const btn = document.getElementById("menu-btn");
    const menu = document.querySelector("[data-mobile-menu]");

    let open = false;

    btn?.addEventListener("click", () => {
        open = !open;

        menu?.classList.toggle("opacity-0");
        menu?.classList.toggle("pointer-events-none");
    });

    const observer = new IntersectionObserver(
        (entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    const id = entry.target.id;

                    if (id === "inicio") {
                        header.classList.add("text-fondo");
                        header.classList.remove("text-primario");
                        header.classList.add("bg-transparent");
                        header.classList.remove("bg-fondo");
                    } else {
                        header.classList.add("text-primario");
                        header.classList.remove("text-fondo");
                        header.classList.add("bg-fondo");
                        header.classList.remove("bg-transparent");
                    }
                }
            });
        },
        {
            threshold: 0.6,
        },
    );

    sections.forEach((section) => observer.observe(section));
</script>
