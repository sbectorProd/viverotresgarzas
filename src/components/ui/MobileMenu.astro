---
import { menú } from "@/constants.ts";

interface Props {
  open: boolean;
}

const { open } = Astro.props as Props;
---

<div data-mobile-menu
  class={`fixed top-0 right-0 z-50 transition-all duration-300 ${
    open ? "opacity-100 pointer-events-auto" : "opacity-0 pointer-events-none"
  }`}
>
  <div class="bg-primario text-fondo shadow-xl px-6 py-6 min-w-[18rem]">
    <div class="flex justify-end">
      <button
        id="close-menu-btn"
        class="absolute top-3 right-5 h-10 w-10 items-center justify-center text-fondo/80 transition hover:text-fondo"
        aria-label="Cerrar menú"
        type="button"
      >
        <span class="text-2xl leading-none">×</span>
      </button>
    </div>

    <nav class="flex flex-col gap-4 text-lg mt-4">
      {menú.map(item => (
        <a href={item.href} class="hover:opacity-70">{item.name}</a>
      ))}
    </nav>
  </div>
</div>