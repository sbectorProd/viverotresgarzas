---
import Section from "@/components/ui/Section.astro";
import Container from "@/components/ui/Container.astro";
import { getEntry } from "astro:content";

const servicios = await getEntry("servicios", "servicios");

if (!servicios) {
    throw new Error("servicios content not found");
}

const projects = servicios.data.servicios_lista ?? [];
---

<Section id="servicios" align="start" justify="center">
    <Container className="lg:max-w-full 2xl:max-w-7xl">
        <!-- Encabezado -->
        <div class="mb-10 lg:mb-14 lg:pt-32">
            <h2 class="type-h2 text-primario max-w-lg">
                {servicios.data.encabezado}
            </h2>
        </div>

        <!-- Layout: imagen izquierda, servicios derecha -->
        <div class="flex flex-col md:flex-row gap-10 xl:gap-24 items-start">
            <!-- Imagen -->
            {servicios.data.imagen && (
                <div class="w-full md:w-[44%] lg:w-[44%] xl:w-[42%] shrink-0">
                    <img
                        src={servicios.data.imagen}
                        alt="Servicios Vivero Tres Garzas"
                        class="w-full h-auto max-h-300 object-cover rounded-3xl"
                    />
                </div>
            )}

            <!-- Lista de servicios -->
            <div class="flex flex-col gap-10 xl:gap-14 md:w-[56%] lg:w-[56%] xl:w-[58%]">
                {projects.map((servicio) => (
                    <div class="flex gap-5 items-start">
                        <span class="w-4 h-4 rounded-full bg-primario shrink-0 mt-2"></span>
                        <div>
                            <p class="type-h2 text-primario mb-2">
                                {servicio.titulo}
                            </p>
                            <p class="type-body text-primario/80">
                                {servicio.descripcion}
                            </p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </Container>
</Section>
