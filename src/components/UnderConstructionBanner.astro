---
const message = "Sitio en construcción";
---

<div id="banner" class="fixed bottom-0 left-0 w-full z-50 pointer-events-none">
  <div class="mx-auto max-w-64 px-4 pb-4">
    
    <div
      class="pointer-events-auto backdrop-blur-md bg-black/70 text-white type-sm px-4 py-2 rounded-full shadow-lg flex items-center justify-between gap-3"
    >
      <span class="opacity-80">{message}</span>

      <button
        onclick="document.getElementById('banner').style.display='none'"
        class="text-white/70 hover:text-white transition-colors"
        aria-label="Cerrar"
      >
        ✕
      </button>
    </div>

  </div>
</div>