---
const message = "Sitio en construcción — algunas secciones pueden no estar disponibles";
---

<div class="fixed bottom-0 left-0 w-full z-50 pointer-events-none">
  <div class="mx-auto max-w-5xl px-4 pt-4">
    
    <div
      class="pointer-events-auto backdrop-blur-md bg-black/70 text-white text-xs md:text-sm px-4 py-2 rounded-full shadow-lg flex items-center justify-center"
    >
      <span class="opacity-80">{message}</span>
    </div>

  </div>
</div>